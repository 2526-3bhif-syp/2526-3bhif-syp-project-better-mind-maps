<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="htl.leonding.at.MainController"
            stylesheets="@styles.css">
    <top>
        <HBox styleClass="toolbar" alignment="CENTER_LEFT">
            <Button text="← Overview" onAction="#onBackToOverview" styleClass="btn-ghost"/>
            <Button text="+ New Mind Map" onAction="#onCreateNewMap" styleClass="btn-primary"/>
        </HBox>
    </top>
    <center>
        <HBox>
            <!-- Sidebar: header + tree on the same level as tabs -->
            <VBox prefWidth="200" minWidth="200" maxWidth="200"
                  style="-fx-border-color: #dee2e6; -fx-border-width: 0 1 0 0;">
                <HBox fx:id="sidebarHeader" styleClass="sidebar-header" alignment="CENTER_LEFT">
                    <Label text="STRUCTURE" styleClass="sidebar-label"/>
                </HBox>
                <TreeView fx:id="hierarchyTree" styleClass="tree-view" VBox.vgrow="ALWAYS"/>
            </VBox>
            <!-- Editor: TabPane fills remaining space -->
            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE"
                     HBox.hgrow="ALWAYS"
                     style="-fx-background-color: #f8f9fa;"/>
        </HBox>
    </center>
    <bottom>
        <HBox styleClass="statusbar" alignment="CENTER_LEFT">
            <Label text="Enter / Ins" styleClass="statusbar-key"/>
            <Label text="Add child" styleClass="statusbar-desc"/>
            <Label text="F2" styleClass="statusbar-key"/>
            <Label text="Edit" styleClass="statusbar-desc"/>
            <Label text="Del" styleClass="statusbar-key"/>
            <Label text="Delete" styleClass="statusbar-desc"/>
            <Label text="Arrow keys" styleClass="statusbar-key"/>
            <Label text="Navigate" styleClass="statusbar-desc"/>
            <Label text="Tab" styleClass="statusbar-key"/>
            <Label text="Cycle nodes" styleClass="statusbar-desc"/>
        </HBox>
    </bottom>
</BorderPane>
