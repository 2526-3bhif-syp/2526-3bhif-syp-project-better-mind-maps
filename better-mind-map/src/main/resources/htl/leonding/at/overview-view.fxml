<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="htl.leonding.at.OverviewController"
            stylesheets="@styles.css"
            style="-fx-background-color: #f0f4f8;">
    <top>
        <HBox styleClass="toolbar" alignment="CENTER_LEFT">
            <VBox spacing="2">
                <Label text="Better Mind Maps" styleClass="app-title"/>
                <Label text="Organize your thoughts visually" styleClass="app-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ New Mind Map" onAction="#onNewMap" styleClass="btn-primary"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="14">
            <padding>
                <Insets bottom="30" left="48" right="48" top="28"/>
            </padding>
            <Label text="Your Mind Maps" styleClass="section-label"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-border-width: 0;">
                <VBox fx:id="cardsContainer" spacing="10"/>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
